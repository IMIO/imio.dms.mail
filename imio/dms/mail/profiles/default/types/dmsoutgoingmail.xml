<?xml version="1.0"?>
<object name="dmsoutgoingmail" meta_type="Dexterity FTI" i18n:domain="plone"
   xmlns:i18n="http://xml.zope.org/namespaces/i18n">
 <property name="icon_expr">string:${portal_url}/++resource++imio.dms.mail/dmsoutgoingmail_icon.png</property>
 <property name="behaviors" purge="False">
  <element value="plone.app.content.interfaces.INameFromTitle"/>
  <element value="plone.app.dexterity.behaviors.metadata.IDublinCore"/>
  <element value="plone.app.lockingbehavior.behaviors.ILocking" />
  <element value="plone.app.versioningbehavior.behaviors.IVersionable" />
  <element value="collective.classification.folder.behaviors.classification_folder.IClassificationFolder" />
  <element value="collective.dexteritytextindexer.behavior.IDexterityTextIndexer" />
  <element value="collective.task.behaviors.ITaskContainer" />
  <element value="collective.task.behaviors.ITask" />
  <element value="imio.dms.mail.content.behaviors.ISigningBehavior" />
 </property>
 <!--property name="klass">imio.dms.mail.dmsmail.ImioDmsOutgoingMail</property-->
 <property name="klass">imio.dms.mail.dmsmail.ImioDmsOutgoingMail</property>
 <property name="schema_policy">schema_policy_imiodmsoutgoingmail</property>
 <property name="allowed_content_types">
  <element value="dmsommainfile"/>
  <element value="dmsappendixfile"/>
  <element value="task"/>
 </property>
 <alias from="edit" to="@@dmsdocument-edit"/>
 <action title="Manage approvals" action_id="manage-approvals" category="object_buttons"
         condition_expr="python: object.portal_workflow.getInfoFor(object, 'review_state') == 'to_approve' and object.has_approvings()"
         description="" icon_expr="string:${portal_url}/++resource++imio.dms.mail/check-all.svg" link_target=""
         url_expr="string:${object/absolute_url}/@@approvals" visible="True">
  <permission value="Manage portal"/>
 </action>
 <action title="Annotation info" action_id="session-annotation-info" category="object_buttons"
         condition_expr="object/session-annotation-info/available"
         description="" icon_expr="string:${portal_url}/info.png" link_target="_blank"
         url_expr="string:${object/absolute_url}/@@session-annotation-info?context_uid=${object/UID}" visible="True">
  <permission value="Manage portal"/>
 </action>
</object>
